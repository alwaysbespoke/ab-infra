{
  "name": "ab-infra-cdk",
  "version": "0.1.0",
  "private": true,
  "description": "CDK app for AWS resources in ab-infra (alwaysbespoke parent-org account).",
  "bin": {
    "ab-infra": "bin/ab-infra.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "synth:shared-use1": "cdk synth --context env=shared --context region=us-east-1",
    "diff:shared-use1": "cdk diff --context env=shared --context region=us-east-1",
    "deploy:shared-use1": "cdk deploy --context env=shared --context region=us-east-1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "aws-cdk": "^2.180.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.180.0",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21"
  }
}
